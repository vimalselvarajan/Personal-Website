---
const links = [
  { href: '/', label: 'Home' },
  { href: '/research', label: 'Research' },
  { href: '/projects', label: 'Projects' },
];

const currentPath = Astro.url.pathname;
---

<header
  id="nav-header"
  class="fixed top-0 inset-x-0 z-50 h-16 transition-all duration-300"
>
  <!-- Desktop: logo left, links right -->
  <div class="hidden md:flex items-center justify-between h-full px-12">

    <!-- Left: logo -->
    <a href="/" aria-label="Home" class="logo-link">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" width="42" height="42" fill="currentColor" aria-hidden="true">
